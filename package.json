{
   "name": "ors-client",
   "version": "1.1.0",
   "type": "module",
   "description": "Modern JavaScript/TypeScript client for OpenRouteService API with full type safety and zero runtime dependencies",
   "main": "dist/index.cjs",
   "module": "dist/index.js",
   "types": "dist/index.d.ts",
   "files": [
      "dist"
   ],
   "exports": {
      ".": {
         "types": "./dist/index.d.ts",
         "import": "./dist/index.js",
         "require": "./dist/index.cjs"
      }
   },
   "scripts": {
      "build": "tsup",
      "lint": "eslint src --ext .ts",
      "lint:fix": "eslint src --ext .ts --fix",
      "type-check": "tsc --noEmit",
      "test": "bun test",
      "dev": "tsup --watch",
      "clean": "bun -e \"import{rmSync}from'fs';try{rmSync('dist',{recursive:true,force:true})}catch{}\"",
      "prepublishOnly": "bun run clean && bun run lint && bun run type-check && bun run build"
   },
   "keywords": [
      "openrouteservice",
      "routing",
      "directions",
      "geocoding",
      "typescript",
      "api-client",
      "maps",
      "navigation",
      "heigit",
      "osrm",
      "route",
      "elevation",
      "isochrones",
      "matrix",
      "poi",
      "optimization"
   ],
   "author": "Kőrösfalvi \"K4ryuu\" Martin",
   "license": "MIT",
   "repository": {
      "type": "git",
      "url": "git+https://github.com/K4ryuu/ors-client.git"
   },
   "devDependencies": {
      "@typescript-eslint/eslint-plugin": "latest",
      "@typescript-eslint/parser": "latest",
      "bun-types": "latest",
      "eslint": "latest",
      "eslint-plugin-unused-imports": "latest",
      "tsup": "latest",
      "typescript": "latest"
   },
   "engines": {
      "node": ">=18.0.0",
      "bun": ">=1.0.0"
   },
   "sideEffects": false
}
